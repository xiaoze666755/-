-- 启动加载
local WindUI, loadErr = tryLoadWindUI(5, 7, 7)

-- 加载失败处理
if not WindUI then
    FallbackNotify(
        "加载失败",
        "UI库加载失败，请更换网络或重新注入\n错误：" .. tostring(loadErr),
        10
    )

    warn("[WindUI] 最终加载失败：" .. tostring(loadErr))
    return
end

